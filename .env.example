# Shared Brain — 环境配置
# 复制本文件为 .env 并填入你的配置
# 最小配置只需要 BRAIN_PROFILE + BRAIN_DATABASE_URI

# ── 必填 ──

BRAIN_PROFILE=your_name

# 从 Supabase Dashboard → Settings → Database → Connection string (URI) 获取
BRAIN_DATABASE_URI=postgresql://postgres.你的项目ID:密码@aws-xxx.pooler.supabase.com:5432/postgres

# ── 可选（一个 key 启用全部高级功能：LLM + 语义搜索 + 知识获取） ──

# OPENROUTER_API_KEY=sk-or-xxx

# ── 高级配置（通常不需要改） ──

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-3.1-flash-lite-preview
LLM_MODEL_OMNI=xiaomi/mimo-v2-omni
# FIRECRAWL_API_KEY=fc-xxx  (用于 learn/search，初始化时自动同步到 brain.secrets 表)
