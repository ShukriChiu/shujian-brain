# 共享大脑 — 环境配置
# 复制本文件为 .env 并填入你的配置

BRAIN_PROFILE=your_name

# 数据库（Supabase PostgreSQL）
BRAIN_DATABASE_URI=postgresql://postgres.xxx:password@aws-xxx.pooler.supabase.com:5432/postgres

# Embedding（Supabase Edge Function）
BRAIN_EMBED_URL=https://xxx.supabase.co/functions/v1/embed
BRAIN_API_KEY=your-api-key

# LLM (OpenRouter) — 可选，用于高级功能：learn/search/reflect/synthesize/see
# 基础的记忆读写和 AGENTS.md 生成不需要 LLM
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-3.1-flash-lite-preview
LLM_MODEL_OMNI=xiaomi/mimo-v2-omni
# OPENROUTER_API_KEY=sk-xxx  (初始化时设这里，后续会同步到 brain.secrets 表)
# FIRECRAWL_API_KEY=fc-xxx   (初始化时设这里，后续会同步到 brain.secrets 表，用于 learn/search)
